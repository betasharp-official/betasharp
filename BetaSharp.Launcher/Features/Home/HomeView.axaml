<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BetaSharp.Launcher.Features.Home"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"

             x:Class="BetaSharp.Launcher.Features.Home.HomeView" x:DataType="local:HomeViewModel">

    <UserControl.Styles>
        <Style Selector="Button.play-button:disabled">
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style Selector="Button.play-button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#116f34" />
            <Setter Property="BorderBrush" Value="#0f5027" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto *" IsVisible="{CompiledBinding Session, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Grid ColumnDefinitions="* Auto" Grid.Row="0">
            <StackPanel Spacing="25" HorizontalAlignment="Stretch" Orientation="Horizontal" Grid.Row="0">
                <Border Width="50" Height="50" ClipToBounds="True" CornerRadius="{StaticResource ControlCornerRadius}">
                    <asyncImageLoader:AdvancedImage Source="{Binding Session.Face, FallbackValue='...'}" RenderOptions.BitmapInterpolationMode="None" Stretch="UniformToFill">
                        <asyncImageLoader:AdvancedImage.Styles>
                            <Style Selector="asyncImageLoader|AdvancedImage">
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.5" />
                                    </Transitions>
                                </Setter>
                            </Style>

                            <Style Selector="asyncImageLoader|AdvancedImage[IsLoading=True]">
                                <Setter Property="Opacity" Value="0" />
                            </Style>

                            <Style Selector="asyncImageLoader|AdvancedImage[IsLoading=False]">
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                        </asyncImageLoader:AdvancedImage.Styles>
                    </asyncImageLoader:AdvancedImage>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Welcome" Opacity="0.5" />

                    <TextBlock Text="{CompiledBinding Session.Name, FallbackValue='...'}"
                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <Button Content="Sign out" Command="{CompiledBinding SignOutCommand}" VerticalAlignment="Center" Grid.Column="1" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
            <!-- ReSharper disable once Xaml.StyleClassNotFound -->
            <Button Content="{CompiledBinding PlayButtonText}"
                    Command="{CompiledBinding PlayCommand}"
                    Classes="play-button"
                    IsEnabled="{CompiledBinding IsPlayActionEnabled}"
                    Background="{CompiledBinding PlayButtonBackground}"
                    Opacity="{CompiledBinding PlayButtonOpacity}"
                    Foreground="White" />

            <Border Height="1" Background="#33FFFFFF" Margin="0,6,0,2" />

            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Dedicated server" FontWeight="SemiBold" />
                <TextBlock Text="Status:" FontWeight="SemiBold" Opacity="0.7" />
                <TextBlock Text="{CompiledBinding DedicatedServerStatusLabel}"
                           Foreground="{CompiledBinding DedicatedServerStatusBrush}"
                           ToolTip.Tip="{CompiledBinding DedicatedServerStatus}" />
            </StackPanel>

            <Button Command="{CompiledBinding ToggleDedicatedServerCommand}"
                    IsEnabled="{CompiledBinding IsDedicatedServerActionEnabled}"
                    Background="{CompiledBinding DedicatedServerButtonBackground}"
                    Foreground="White">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <PathIcon Width="12"
                              Height="12"
                              Data="{CompiledBinding DedicatedServerButtonIconData}"
                              Foreground="White" />
                    <TextBlock Text="{CompiledBinding DedicatedServerButtonText}" Foreground="White" />
                </StackPanel>
            </Button>

            <Expander Header="Server Settings"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      IsExpanded="{CompiledBinding IsServerSettingsExpanded}">
                <StackPanel Margin="0,8,0,0" Spacing="8" HorizontalAlignment="Stretch">
                    <CheckBox Content="Online mode"
                              IsChecked="{CompiledBinding ServerOnlineMode, Mode=TwoWay}" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8"
                          HorizontalAlignment="Stretch">
                        <TextBlock Text="Server port" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{CompiledBinding ServerPortText, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" Text="Max players" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{CompiledBinding ServerMaxPlayersText, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Text="View distance" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{CompiledBinding ServerViewDistanceText, Mode=TwoWay}" />
                    </Grid>

                    <CheckBox Content="Allow flight"
                              IsChecked="{CompiledBinding ServerAllowFlight, Mode=TwoWay}" />

                    <CheckBox Content="Spawn monsters"
                              IsChecked="{CompiledBinding ServerSpawnMonsters, Mode=TwoWay}" />

                    <TextBlock Text="{CompiledBinding ServerSettingsValidationMessage}"
                               IsVisible="{CompiledBinding HasServerSettingsValidationError}"
                               Foreground="#EF4444"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Settings changes apply on next server start."
                               IsVisible="{CompiledBinding ShowServerSettingsRestartHint}"
                               Opacity="0.7" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>
